---
interface Props {
  id?: string;
  label?: string;
  placeholder?: string;
  checkinName?: string;
  checkoutName?: string;
  required?: boolean;
  lang?: 'es' | 'en';
}

const {
  id = 'stay-range',
  label = 'Fechas de estadía',
  placeholder = 'Selecciona ingreso y salida',
  checkinName = 'checkin',
  checkoutName = 'checkout',
  required = true,
  lang = 'es'
} = Astro.props;
---

<div class="form-group">
  <label class="label text-black" for={id}>{label}</label>
  <div class="relative">
    <input
      id={id}
      type="text"
      placeholder={placeholder}
      readonly
      data-lang={lang}
      data-checkin-name={checkinName}
      data-checkout-name={checkoutName}
      data-required={required ? 'true' : 'false'}
      class="input-field h-[42px] pr-10 text-black border-gray-500 placeholder:text-gray-700 cursor-pointer date-range-input"
    />
    <input type="hidden" name={checkinName} data-checkin-hidden={id} />
    <input type="hidden" name={checkoutName} data-checkout-hidden={id} />
    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
  </div>
</div>

<script is:inline>
  // ─── Helpers ────────────────────────────────────────────────────────────────

  function _drpFormatDateISO(date) {
    return date.toLocaleDateString('en-CA');
  }

  function _drpFormatRangeLabel(start, end, lang) {
    var diffMs = end.getTime() - start.getTime();
    var nights = Math.max(0, Math.round(diffMs / (1000 * 60 * 60 * 24)));
    var nightLabel = lang === 'en'
      ? (nights === 1 ? '1 night' : nights + ' nights')
      : (nights === 1 ? '1 noche' : nights + ' noches');
    return _drpFormatDateISO(start) + ' -> ' + _drpFormatDateISO(end) + ' (' + nightLabel + ')';
  }

  // ─── Picker initializer ─────────────────────────────────────────────────────

  function _drpInitPicker(input) {
    if (input.dataset.flatpickrInitialized === 'true') return;
    if (!window.flatpickr) return;

    var pickerId = input.id;
    var checkinHidden = document.querySelector('[data-checkin-hidden="' + pickerId + '"]');
    var checkoutHidden = document.querySelector('[data-checkout-hidden="' + pickerId + '"]');

    if (!checkinHidden || !checkoutHidden) return;

    var inputLang = input.dataset.lang === 'en' ? 'en' : 'es';
    var isRequired = input.dataset.required === 'true';

    function emitRangeChange() {
      input.dispatchEvent(new CustomEvent('date-range:change', {
        bubbles: true,
        detail: {
          id: pickerId,
          checkin: checkinHidden.value,
          checkout: checkoutHidden.value,
          hasRange: Boolean(checkinHidden.value && checkoutHidden.value),
        },
      }));
    }

    // Resolve locale object: flatpickr l10n for 'es', default for 'en'
    var localeObj = (inputLang === 'es' && window.flatpickr.l10ns && window.flatpickr.l10ns.es)
      ? window.flatpickr.l10ns.es
      : undefined;

    // ── Editing-guard state ─────────────────────────────────────────────────
    // Tracks whether the user is mid-selection so we don't hide extras while
    // they are picking the second date of a new range.
    var _editing = false;          // true while the calendar is open
    var _rangeConfirmed = false;   // true once a full range is chosen in this session
    var _previousCheckin = '';
    var _previousCheckout = '';
    var _previousLabel = '';

    window.flatpickr(input, {
      mode: 'range',
      minDate: 'today',
      dateFormat: 'Y-m-d',
      locale: localeObj,
      allowInput: false,
      onOpen: function() {
        // Snapshot the current valid range before the user starts editing
        _editing = true;
        _rangeConfirmed = false;
        _previousCheckin  = checkinHidden.value;
        _previousCheckout = checkoutHidden.value;
        _previousLabel    = input.value;
      },
      onChange: function(selectedDates) {
        if (selectedDates.length < 2) {
          // User clicked the first date of a new range.
          // If we already had a confirmed range, keep the hidden inputs intact
          // so the extras row stays visible while they pick the second date.
          if (_editing && (_previousCheckin && _previousCheckout)) {
            // Preserve previous values — do NOT call emitRangeChange yet
            return;
          }
          // No previous range: truly empty state
          checkinHidden.value  = '';
          checkoutHidden.value = '';
          if (!isRequired) input.value = '';
          emitRangeChange();
          return;
        }

        var start = selectedDates[0];
        var end   = selectedDates[1];

        if (start.toDateString() === end.toDateString()) {
          // Same-day selection — restore previous range and warn
          checkinHidden.value  = _previousCheckin;
          checkoutHidden.value = _previousCheckout;
          input.value          = _previousLabel;
          setTimeout(function() {
            if (window._currentFlatpickrInstance) {
              window._currentFlatpickrInstance.clear();
              if (_previousCheckin && _previousCheckout) {
                window._currentFlatpickrInstance.setDate(
                  [new Date(_previousCheckin), new Date(_previousCheckout)],
                  false
                );
              }
            }
          }, 0);
          alert('Debes seleccionar al menos 2 días diferentes.');
          emitRangeChange();
          return;
        }

        // Full valid range selected
        checkinHidden.value  = _drpFormatDateISO(start);
        checkoutHidden.value = _drpFormatDateISO(end);
        input.value          = _drpFormatRangeLabel(start, end, inputLang);
        _rangeConfirmed      = true;
        emitRangeChange();
      },
      onClose: function(selectedDates) {
        // If the user closed the picker without completing a new range,
        // restore the previous range (or clear if there was none).
        if (_editing && !_rangeConfirmed) {
          if (_previousCheckin && _previousCheckout) {
            // Restore the old range silently
            checkinHidden.value  = _previousCheckin;
            checkoutHidden.value = _previousCheckout;
            input.value          = _previousLabel;
            // Re-sync the picker UI without firing onChange
            if (window._currentFlatpickrInstance) {
              window._currentFlatpickrInstance.setDate(
                [new Date(_previousCheckin), new Date(_previousCheckout)],
                false
              );
            }
          } else {
            // Was empty before — truly clear
            checkinHidden.value  = '';
            checkoutHidden.value = '';
            input.value          = '';
          }
          emitRangeChange();
        }
        _editing       = false;
        _rangeConfirmed = false;
      },
      onReady: function(_selectedDates, _dateStr, instance) {
        // Store reference for same-day clear workaround
        window._currentFlatpickrInstance = instance;

        // Restore pre-existing hidden values (e.g. sync between standard ↔ group modes)
        if (checkinHidden.value && checkoutHidden.value) {
          var start = new Date(checkinHidden.value);
          var end   = new Date(checkoutHidden.value);
          if (!isNaN(start.getTime()) && !isNaN(end.getTime())) {
            instance.setDate([start, end], true);
          }
        }
        input.dataset.flatpickrInitialized = 'true';
        emitRangeChange();
      },
    });
  }

  // ─── Init all pickers ───────────────────────────────────────────────────────

  function initializeDateRangePickers() {
    document.querySelectorAll('.date-range-input').forEach(function(input) {
      if (input instanceof HTMLInputElement) {
        _drpInitPicker(input);
      }
    });
  }

  // ─── Dynamic loader (Bug #1 fix) ────────────────────────────────────────────
  // Loads CSS → flatpickr.min.js → es locale in strict order via onload
  // Guards against double-loading when multiple instances are on the page (Bug #2 fix)

  function _drpLoadAndInit() {
    // 1. CSS — inject once
    if (!document.getElementById('flatpickr-css')) {
      var link = document.createElement('link');
      link.id = 'flatpickr-css';
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css';
      document.head.appendChild(link);
    }

    // 2. If flatpickr is already available, go straight to init
    if (window.flatpickr) {
      initializeDateRangePickers();
      return;
    }

    // 3. If a load is already in progress, queue this init call
    if (window._flatpickrLoading) {
      window._flatpickrQueue = window._flatpickrQueue || [];
      window._flatpickrQueue.push(initializeDateRangePickers);
      return;
    }

    // 4. Start loading flatpickr for the first time
    window._flatpickrLoading = true;
    window._flatpickrQueue = [initializeDateRangePickers];

    var script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js';
    script.onload = function() {
      // 5. Load Spanish locale after flatpickr core is ready
      var localeScript = document.createElement('script');
      localeScript.src = 'https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/l10n/es.js';
      localeScript.onload = function() {
        window._flatpickrLoading = false;
        var queue = window._flatpickrQueue || [];
        window._flatpickrQueue = [];
        queue.forEach(function(fn) { fn(); });
      };
      localeScript.onerror = function() {
        // Locale failed but flatpickr core is available — init without locale
        window._flatpickrLoading = false;
        var queue = window._flatpickrQueue || [];
        window._flatpickrQueue = [];
        queue.forEach(function(fn) { fn(); });
      };
      document.head.appendChild(localeScript);
    };
    script.onerror = function() {
      console.error('[DateRangePicker] Failed to load flatpickr from CDN.');
      window._flatpickrLoading = false;
      window._flatpickrQueue = [];
    };
    document.head.appendChild(script);
  }

  // ─── Entry points ────────────────────────────────────────────────────────────

  // Expose so external code can re-trigger (kept for backward compat)
  window.initializeDateRangePickers = initializeDateRangePickers;

  // Standard page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _drpLoadAndInit);
  } else {
    _drpLoadAndInit();
  }

  // Astro view transitions
  document.addEventListener('astro:page-load', _drpLoadAndInit);
</script>
