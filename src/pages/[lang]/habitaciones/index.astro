---
import Layout from '@layouts/Layout.astro';
import RoomCard from '@organisms/cards/RoomCard.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = lang || 'es';
const isEn = currentLang === 'en';

type RoomCategory = 'estandar' | 'doble' | 'suite';

interface Room {
  id: string;
  title: string;
  price: number;
  category: RoomCategory;
  capacity: number;
  size: string;
  description: string;
  features: string[];
  popular: boolean;
}

const rooms: Room[] = [
  {
    id: 'estandar',
    title: isEn ? 'Standard Room' : 'Habitación Estándar',
    price: 65,
    category: 'estandar',
    capacity: 2,
    size: '25m²',
    description: isEn 
      ? 'Cozy room with queen bed and city view. Perfect for travelers seeking comfort at an excellent price.'
      : 'Habitación cómoda con cama queen y vista a la ciudad. Perfecta para viajeros que buscan comodidad a un excelente precio.',
    features: isEn 
      ? ['Free WiFi', 'Flat-screen TV', 'Air conditioning', 'Private bathroom', 'Desk', 'Telephone']
      : ['WiFi gratis', 'TV pantalla plana', 'Aire acondicionado', 'Baño privado', 'Escritorio', 'Teléfono'],
    popular: false
  },
  {
    id: 'estandar-premium',
    title: isEn ? 'Premium Standard Room' : 'Habitación Estándar Premium',
    price: 75,
    category: 'estandar',
    capacity: 2,
    size: '28m²',
    description: isEn
      ? 'Spacious room with king bed and work area. Ideal for business stays.'
      : 'Habitación espaciosa con cama king y zona de trabajo. Ideal para estancias de negocios.',
    features: isEn
      ? ['Free WiFi', 'Flat-screen TV', 'Air conditioning', 'Private bathroom', 'Minibar', 'Safe']
      : ['WiFi gratis', 'TV pantalla plana', 'Aire acondicionado', 'Baño privado', 'Minibar', 'Caja fuerte'],
    popular: false
  },
  {
    id: 'doble',
    title: isEn ? 'Double Room' : 'Habitación Doble',
    price: 85,
    category: 'doble',
    capacity: 4,
    size: '35m²',
    description: isEn
      ? 'Spacious room with two queen beds, ideal for families or small groups.'
      : 'Espaciosa habitación con dos camas queen, ideal para familias o grupos pequeños.',
    features: isEn
      ? ['Free WiFi', 'Flat-screen TV', 'Minibar', 'Safe', 'Air conditioning', 'Telephone']
      : ['WiFi gratis', 'TV pantalla plana', 'Minibar', 'Caja fuerte', 'Aire acondicionado', 'Teléfono'],
    popular: true
  },
  {
    id: 'doble-familiar',
    title: isEn ? 'Family Double Room' : 'Habitación Doble Familiar',
    price: 95,
    category: 'doble',
    capacity: 5,
    size: '40m²',
    description: isEn
      ? 'Family room with two queen beds and seating area. Perfect for families.'
      : 'Habitación familiar con dos camas queen y zona de estar. Perfecta para familias.',
    features: isEn
      ? ['Free WiFi', 'Flat-screen TV', 'Minibar', 'Seating area', 'Air conditioning', 'Safe']
      : ['WiFi gratis', 'TV pantalla plana', 'Minibar', 'Sala de estar', 'Aire acondicionado', 'Caja fuerte'],
    popular: false
  },
  {
    id: 'suite',
    title: isEn ? 'Junior Suite' : 'Suite Junior',
    price: 120,
    category: 'suite',
    capacity: 2,
    size: '45m²',
    description: isEn
      ? 'Elegant suite with private living room and spacious bedroom. Luxury in the colonial heart.'
      : 'Suite elegante con sala de estar privada y habitación espaciosa. Lujo en el corazón colonial.',
    features: isEn
      ? ['Living room', 'Minibar', 'Safe', 'Marble bathroom', 'Room service', 'Balcony']
      : ['Sala de estar', 'Minibar', 'Caja fuerte', 'Baño de mármol', 'Servicio a la habitación', 'Balcón'],
    popular: false
  },
  {
    id: 'suite-presidencial',
    title: isEn ? 'Presidential Suite' : 'Suite Presidencial',
    price: 150,
    category: 'suite',
    capacity: 2,
    size: '55m²',
    description: isEn
      ? 'The ultimate experience: luxury colonial suite with jacuzzi and balcony overlooking the historic center.'
      : 'La experiencia definitiva: suite de lujo colonial con jacuzzi y balcón con vista al centro histórico.',
    features: isEn
      ? ['Living room', 'Balcony', 'Jacuzzi', 'Room service', 'Safe', 'Marble bathroom']
      : ['Sala de estar', 'Balcón', 'Jacuzzi', 'Servicio a la habitación', 'Caja fuerte', 'Baño de mármol'],
    popular: false
  }
];

const categories = [
  { id: 'estandar', label: isEn ? 'Standard' : 'Estándar', count: 2 },
  { id: 'doble', label: isEn ? 'Double' : 'Doble', count: 2 },
  { id: 'suite', label: 'Suite', count: 2 }
];

const title = isEn ? 'Our Rooms' : 'Nuestras Habitaciones';
const subtitle = isEn ? 'Find the perfect space for your stay in Cuenca' : 'Encuentra el espacio perfecto para tu estancia en Cuenca';
---

<Layout lang={currentLang} title={title}>
  <!-- Hero -->
  <section class="relative h-64 md:h-80 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=1920&q=80" 
        alt={title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/40"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>
      <p class="text-white/90 text-lg max-w-2xl mx-auto">{subtitle}</p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <div class="bg-white border-b border-gray-100 sticky top-20 z-30">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <div class="flex items-center justify-center space-x-4 overflow-x-auto">
        <button class="filter-btn active px-6 py-2 rounded-full bg-primary text-white font-medium transition-colors" data-filter="all">
          {isEn ? 'All' : 'Todas'} ({rooms.length})
        </button>
        {categories.map((cat) => (
          <button class="filter-btn px-6 py-2 rounded-full border border-primary text-primary hover:bg-primary hover:text-white font-medium transition-colors" data-filter={cat.id}>
            {cat.label} ({cat.count})
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Rooms Grid -->
  <section class="py-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rooms.map((room) => (
          <RoomCard 
            title={room.title}
            price={room.price}
            category={room.category}
            capacity={room.capacity}
            size={room.size}
            description={room.description}
            features={room.features}
            popular={room.popular}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display text-2xl font-bold text-primary mb-6 text-center">{isEn ? 'Important Information' : 'Información importante'}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-background-warm p-6 rounded-xl">
          <h3 class="font-display font-bold text-primary mb-4 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {isEn ? 'Schedule' : 'Horarios'}
          </h3>
          <ul class="space-y-2 text-text-light">
            <li><strong>{isEn ? 'Check-in:' : 'Check-in:'}</strong> 14:00 - 23:00</li>
            <li><strong>{isEn ? 'Check-out:' : 'Check-out:'}</strong> 11:00</li>
            <li><strong>{isEn ? 'Reception:' : 'Recepción:'}</strong> 24 {isEn ? 'hours' : 'horas'}</li>
          </ul>
        </div>

        <div class="bg-background-warm p-6 rounded-xl">
          <h3 class="font-display font-bold text-primary mb-4 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {isEn ? 'Policies' : 'Políticas'}
          </h3>
          <ul class="space-y-2 text-text-light">
            <li>{isEn ? 'Free cancellation up to 48h before' : 'Cancelación gratuita hasta 48h antes'}</li>
            <li>{isEn ? 'No pets allowed' : 'No se permiten mascotas'}</li>
            <li>{isEn ? 'Children under 12 years old free' : 'Niños menores de 12 años gratis'}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-accent">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-4">
        {isEn ? 'Have questions?' : '¿Tienes preguntas?'}
      </h2>
      <p class="text-white/90 mb-6">
       {isEn ? 'Our team is ready to help you choose the perfect room.' : 'Nuestro equipo está listo para ayudarte a elegir la habitación perfecta.'}
      </p>
      <a href="https://wa.me/593980098757" target="_blank" class="inline-flex items-center bg-white text-accent hover:bg-gray-100 font-bold py-3 px-6 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {isEn ? 'Write to us via WhatsApp' : 'Escríbenos por WhatsApp'}
      </a>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
  const roomCards = document.querySelectorAll<HTMLElement>('.card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter') || 'all';
      
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('border', 'border-primary', 'text-primary');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('border', 'border-primary', 'text-primary');
      
      roomCards.forEach(card => {
        if (filter === 'all' || card.classList.contains(filter)) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>