---
import Layout from '@layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = lang || 'es';
const isEn = currentLang === 'en';

const dishes = [
  {
    name: isEn ? 'Encebollado' : 'Encebollado',
    description: isEn 
      ? 'Traditional fish soup in tomato broth with purple onion, yuca and seasoning. The favorite dish of Ecuadorians.'
      : 'Sopa tradicional de pescado en caldo de tomate con cebolla morada, yuca y aliño. El plato favorito de los ecuatorianos.',
    image: 'https://images.unsplash.com/photo-1534482421-64566f976cfa?auto=format&fit=crop&w=600&q=80'
  },
  {
    name: isEn ? 'Roasted Guinea Pig' : 'Cuy Asado',
    description: isEn 
      ? 'Typical roasted guinea pig with potatoes and corn. Delicacy of the Andean region.'
      : 'Cuy típico asado al horno con papas y maiz. Delicia tradicional de la región andina.',
    image: 'https://images.unsplash.com/photo-1600891964092-4316c2888cda?auto=format&fit=crop&w=600&q=80'
  },
  {
    name: isEn ? 'Llapingacho' : 'Llapingacho',
    description: isEn 
      ? 'Mashed potatoes with cheese, chorizo and fried egg. A typical Quito breakfast.'
      : 'Patatas escurdidas con queso, chorizo y huevo frito. Un desayuno típico quiteño.',
    image: 'https://images.unsplash.com/photo-1604152135912-04a022e23696?auto=format&fit=crop&w=600&q=80'
  },
  {
    name: isEn ? 'Hornado' : 'Hornado',
    description: isEn 
      ? 'Pork roasted slowly until achieving a crispy skin. Served with mote and llakta.'
      : 'Cerdo asado lentamente hasta obtener una皮 crujiente. Acompañado de mote y llakta.',
    image: 'https://images.unsplash.com/photo-1606728035253-49e8a23136de?auto=format&fit=crop&w=600&q=80'
  }
];

const restaurants = [
  {
    name: 'Tiestos Café',
    type: isEn ? 'Café & Desserts' : 'Café & Postres',
    description: isEn 
      ? 'Artistic café with cathedral view. Excellent pastries and coffee.'
      : 'Café artístico con vista a la catedral. Excelentes pasteles y coffee.',
    distance: isEn ? '2 min' : '2 min'
  },
  {
    name: 'Molle 1841',
    type: isEn ? 'Ecuadorian Gastronomy' : 'Gastronomía Ecuatoriana',
    description: isEn 
      ? 'Author restaurant with reinvented traditional cuisine. Reservation recommended.'
      : 'Restaurante de autor con cocina tradicional reinventada. Reservación recomendada.',
    distance: isEn ? '5 min' : '5 min'
  },
  {
    name: 'Govindas',
    type: isEn ? 'Vegetarian' : 'Vegetariano',
    description: isEn 
      ? 'Vegetarian and vegan food with organic options. Quiet atmosphere.'
      : 'Comida vegetariana y vegana con opciones orgánicas. Ambiente tranquilo.',
    distance: isEn ? '3 min' : '3 min'
  },
  {
    name: isEn ? 'Mercado 10 de Agosto' : 'Mercado 10 de Agosto',
    type: isEn ? 'Local Market' : 'Mercado Local',
    description: isEn 
      ? 'Traditional market with local food stalls. Authentic culinary experience.'
      : 'Mercado tradicional con puestos de comida local. Auténtica experiencia culinaria.',
    distance: isEn ? '8 min' : '8 min'
  }
];

const title = isEn ? 'Gastronomy of Cuenca' : 'Gastronomía de Cuenca';
const subtitle = isEn ? 'Explore the authentic flavors of Ecuador' : 'Explora los sabores auténticos del Ecuador';
const introTitle = isEn ? 'The Quito Kitchen' : 'La Cocina Quiteña';
const introDesc = isEn 
  ? 'Cuenca is known as the gastronomic capital of Ecuador. Its cuisine reflects the fusion of indigenous and Spanish traditions, creating unique dishes you won\'t find anywhere else in the world.'
  : 'Cuenca es conocida como la capital gastronómica del Ecuador. Su cocina refleja la fusión de tradiciones indígenas y españolas, creando platos únicos que no encontrarás en ningún otro lugar del mundo.';
const dishesTitle = isEn ? 'Must-try Typical Dishes' : 'Platos Típicos Imperdibles';
const restaurantsTitle = isEn ? 'Nearby Restaurants' : 'Restaurantes Cercanos';
const restaurantsSubtitle = isEn 
  ? 'The best places to eat near the hotel, recommended by our team'
  : 'Los mejores lugares para comer cerca del hotel, recomendados por nuestro equipo';
const breakfastTitle = isEn ? 'Breakfast Included' : 'Desayuno Incluido';
const breakfastDesc = isEn 
  ? 'Enjoy our buffet breakfast every morning with hot options, fresh fruits, local bakery and more. Available from 7:00 to 10:00.'
  : 'Disfruta de nuestro desayuno tipo buffet todas las mañanas con opciones calientes, frutas frescas, panadería local y más. Disponible de 7:00 a 10:00.';
const helpTitle = isEn ? 'Need recommendations?' : '¿Necesitas recomendaciones?';
const helpDesc = isEn 
  ? 'Our team can help you reserve tables and recommend the best places.'
  : 'Nuestro equipo puede ayudarte a reservar mesas y recomendar los mejores lugares.';
const ctaBtn = isEn ? 'Ask via WhatsApp' : 'Preguntar por WhatsApp';
---

<Layout lang={currentLang} title={title}>
  <!-- Hero -->
  <section class="relative h-64 md:h-80 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1559329007-40f8a3d6a5c9?auto=format&fit=crop&w=1920&q=80" 
        alt={title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/40"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>
      <p class="text-white/90 text-lg max-w-2xl mx-auto">{subtitle}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-background">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="text-accent font-accent text-lg tracking-widest uppercase">{isEn ? 'Flavors of Ecuador' : 'Sabores del Ecuador'}</span>
      <h2 class="section-title mt-4">{introTitle}</h2>
      <p class="text-text-light text-lg leading-relaxed mt-4">
        {introDesc}
      </p>
    </div>
  </section>

  <!-- Typical Dishes -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-center mb-12">{dishesTitle}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {dishes.map((dish) => (
          <article class="card group overflow-hidden">
            <div class="relative h-48 overflow-hidden">
              <img 
                src={dish.image}
                alt={dish.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            </div>
            <div class="p-4">
              <h3 class="font-display text-lg font-bold text-primary">{dish.name}</h3>
              <p class="text-text-light text-sm mt-2">{dish.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby Restaurants -->
  <section class="py-16 bg-background-warm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-center mb-4">{restaurantsTitle}</h2>
      <p class="text-text-light text-center max-w-2xl mx-auto mb-12">
        {restaurantsSubtitle}
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {restaurants.map((place) => (
          <article class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow flex items-start space-x-4">
            <div class="w-16 h-16 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex items-start justify-between">
                <div>
                  <h3 class="font-display font-bold text-primary">{place.name}</h3>
                  <span class="text-xs text-accent font-medium">{place.type}</span>
                </div>
                <span class="text-sm text-text-muted">{place.distance}</span>
              </div>
              <p class="text-text-light text-sm mt-2">{place.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Breakfast Info -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="bg-accent rounded-2xl p-8 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0-1H8m4 0h4" />
        </svg>
        <h3 class="font-display text-2xl font-bold mb-2">{breakfastTitle}</h3>
        <p class="text-white/90">
          {breakfastDesc}
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display text-2xl font-bold text-white mb-4">{helpTitle}</h2>
      <p class="text-white/80 mb-6">
       {helpDesc}
      </p>
      <a href="https://wa.me/593980098757" target="_blank" class="btn-accent">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {ctaBtn}
      </a>
    </div>
  </section>
</Layout>