---
import Layout from '@layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = lang || 'es';
const isEn = currentLang === 'en';

const title = isEn ? 'Contact' : 'Contacto';
const subtitle = isEn ? 'We are here to help you' : 'Estamos aquí para ayudarte';
const phoneTitle = isEn ? 'Phone' : 'Teléfono';
const phone = '+593 980098757';
const phoneDesc = isEn ? '24 hours' : '24 horas';
const whatsappTitle = 'WhatsApp';
const whatsappBtn = isEn ? 'Send message' : 'Enviar mensaje';
const whatsappDesc = isEn ? 'Immediate response' : 'Respuesta inmediata';
const emailTitle = 'Email';
const email = isEn ? 'reservations@hotelmajestic2.com' : 'reservas@hotelmajestic2.com';
const emailDesc = isEn ? 'We respond within 24h' : 'Respondemos en 24h';
const formTitle = isEn ? 'Send us a message' : 'Envíanos un mensaje';
const nameLabel = isEn ? 'Full name *' : 'Nombre completo *';
const namePlaceholder = isEn ? 'Your name' : 'Tu nombre';
const emailLabel = isEn ? 'Email *' : 'Email *';
const emailPlaceholder = isEn ? 'your@email.com' : 'tu@email.com';
const phoneLabel = isEn ? 'Phone' : 'Teléfono';
const phonePlaceholder = isEn ? '+593 9xxxxxxxx' : '+593 9xxxxxxxx';
const subjectLabel = isEn ? 'Subject *' : 'Asunto *';
const subjectSelect = isEn ? 'Select a subject' : 'Selecciona un asunto';
const subjectReserve = isEn ? 'Room reservation' : 'Reserva de habitación';
const subjectConsult = isEn ? 'General inquiry' : 'Consulta general';
const subjectEvents = isEn ? 'Group events' : 'Eventos grupales';
const subjectFeedback = isEn ? 'Feedback' : 'Comentarios';
const subjectOther = isEn ? 'Other' : 'Otro';
const messageLabel = isEn ? 'Message *' : 'Mensaje *';
const messagePlaceholder = isEn ? 'How can we help you?' : '¿En qué podemos ayudarte?';
const submitBtn = isEn ? 'Send message' : 'Enviar mensaje';
const locationTitle = isEn ? 'Our location' : 'Nuestra ubicación';
const hotelName = 'Hotel Majestic II';
const address = isEn 
  ? 'Gran Colombia Street 2-07<br/>and Manuel Vega<br/>Cuenca, Ecuador'
  : 'Calle Gran Colombia 2-07<br/>y Manuel Vega<br/>Cuenca, Ecuador';
const howToGet = isEn ? 'How to get here' : 'Cómo llegar';
const fromAirport = isEn ? 'From the airport:' : 'Desde el aeropuerto:';
const fromTerminal = isEn ? 'From the bus terminal:' : 'Desde la terminal terrestre:';
const fromCenter = isEn ? 'From the center:' : 'Desde el centro:';
const airportTime = isEn ? '15 min by taxi ($5-8)' : '15 min en taxi ($5-8)';
const terminalTime = isEn ? '10 min by taxi ($3-5)' : '10 min en taxi ($3-5)';
const centerTime = isEn ? 'On foot (5 min)' : 'A pie (5 min)';
const hoursTitle = isEn ? 'Business hours' : 'Horarios de atención';
const receptionTitle = isEn ? 'Reception' : 'Recepción';
const receptionHours = isEn ? '24 hours' : '24 horas';
const receptionDays = isEn ? 'Every day' : 'Todos los días';
const reservationsTitle = isEn ? 'Reservations' : 'Reservas';
const reservationsHours = isEn ? '7:00 - 22:00' : '7:00 - 22:00';
const restaurantTitle = isEn ? 'Restaurant' : 'Restaurant';
const restaurantHours = isEn ? '7:00 - 22:00' : '7:00 - 22:00';
---

<Layout lang={currentLang} title={title}>
  <!-- Hero -->
  <section class="relative h-64 md:h-80 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1566073771259-6a8506079945?auto=format&fit=crop&w=1920&q=80" 
        alt={title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/40"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>
      <p class="text-white/90 text-lg">{subtitle}</p>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section class="py-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Phone -->
        <div class="bg-white rounded-xl p-8 shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-primary mb-2">{phoneTitle}</h3>
          <a href="tel:+593980098757" class="text-text-light hover:text-primary transition-colors block">
            {phone}
          </a>
          <span class="text-sm text-text-muted block mt-1">{phoneDesc}</span>
        </div>

        <!-- WhatsApp -->
        <div class="bg-white rounded-xl p-8 shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-primary mb-2">{whatsappTitle}</h3>
          <a href="https://wa.me/593980098757" target="_blank" class="text-green-500 hover:text-green-600 transition-colors block font-medium">
            {whatsappBtn}
          </a>
          <span class="text-sm text-text-muted block mt-1">{whatsappDesc}</span>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-xl p-8 shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-primary mb-2">{emailTitle}</h3>
          <a href={`mailto:${email}`} class="text-text-light hover:text-primary transition-colors block">
            {email}
          </a>
          <span class="text-sm text-text-muted block mt-1">{emailDesc}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form & Map -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <h2 class="font-display text-2xl font-bold text-primary mb-6">{formTitle}</h2>
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="label" for="name">{nameLabel}</label>
                <input type="text" id="name" name="name" required class="input-field" placeholder={namePlaceholder} />
              </div>
              <div>
                <label class="label" for="email">{emailLabel}</label>
                <input type="email" id="email" name="email" required class="input-field" placeholder={emailPlaceholder} />
              </div>
            </div>
            
            <div>
              <label class="label" for="phone">{phoneLabel}</label>
              <input type="tel" id="phone" name="phone" class="input-field" placeholder={phonePlaceholder} />
            </div>
            
            <div>
              <label class="label" for="subject">{subjectLabel}</label>
              <select id="subject" name="subject" class="input-field" required>
                <option value="">{subjectSelect}</option>
                <option value="reserva">{subjectReserve}</option>
                <option value="consulta">{subjectConsult}</option>
                <option value="eventos">{subjectEvents}</option>
                <option value="feedback">{subjectFeedback}</option>
                <option value="otro">{subjectOther}</option>
              </select>
            </div>
            
            <div>
              <label class="label" for="message">{messageLabel}</label>
              <textarea id="message" name="message" rows="5" required class="input-field resize-none" placeholder={messagePlaceholder}></textarea>
            </div>
            
            <button type="submit" class="btn-primary w-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {submitBtn}
            </button>
          </form>
        </div>

        <!-- Map & Address -->
        <div>
          <h2 class="font-display text-2xl font-bold text-primary mb-6">{locationTitle}</h2>
          
          <div class="bg-background-warm rounded-xl p-6 mb-6">
            <div class="flex items-start space-x-4 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <h3 class="font-display font-bold text-primary">{hotelName}</h3>
                <p class="text-text-light" set:html={address} />
              </div>
            </div>

            <div class="aspect-video rounded-lg overflow-hidden">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3980.920510961731!2d-79.0107346251304!3d-2.8972745!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91cd19b08bbe4bff%3A0xe7258e2651680854!2sHotel%20Majestic%202%20by%20HHG!5e0!3m2!1sen!2sec!4v1650000000000!5m2!1sen!2sec" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          </div>

          <div class="bg-accent rounded-xl p-6 text-white">
            <h3 class="font-display font-bold mb-2 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {howToGet}
            </h3>
            <ul class="text-white/90 text-sm space-y-2">
              <li><strong>{fromAirport}</strong> {airportTime}</li>
              <li><strong>{fromTerminal}</strong> {terminalTime}</li>
              <li><strong>{fromCenter}</strong> {centerTime}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Business Hours -->
  <section class="py-16 bg-background-warm">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="section-title text-center mb-8">{hoursTitle}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-display font-bold text-primary mb-2">{receptionTitle}</h3>
          <p class="text-text-light">{receptionHours}</p>
          <p class="text-text-muted text-sm">{receptionDays}</p>
        </div>
        
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-display font-bold text-primary mb-2">{reservationsTitle}</h3>
          <p class="text-text-light">{reservationsHours}</p>
          <p class="text-text-muted text-sm">{receptionDays}</p>
        </div>
        
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-display font-bold text-primary mb-2">{restaurantTitle}</h3>
          <p class="text-text-light">{restaurantHours}</p>
          <p class="text-text-muted text-sm">{receptionDays}</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const name = formData.get('name');
      const email = formData.get('email');
      const subject = formData.get('subject');
      const message = formData.get('message');
      
      const text = `*Nuevo mensaje de contacto*%0A%0A*Nombre:* ${name}%0A*Email:* ${email}%0A*Asunto:* ${subject}%0A%0A*Mensaje:* ${message}`;
      
      window.open(`https://wa.me/593980098757?text=${text}`, '_blank');
    });
  }
</script>