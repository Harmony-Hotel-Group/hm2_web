---
import Layout from '@layouts/Layout.astro';

const lang = 'es';

const rooms = [
  {
    id: 'estandar',
    title: 'Habitación Estándar',
    price: 65,
    capacity: 2,
    size: '25m²',
    description: 'Cama queen, vista a la ciudad. Perfecta para viajeros que buscan comodidad.',
    features: ['WiFi', 'TV', 'A/C', 'Baño privado'],
    emoji: '🛏️',
    color: 'from-blue-50 to-blue-100',
    border: 'border-blue-200',
    badge: '',
  },
  {
    id: 'estandar-premium',
    title: 'Estándar Premium',
    price: 75,
    capacity: 2,
    size: '28m²',
    description: 'Cama king, zona de trabajo. Ideal para viajes de negocios.',
    features: ['WiFi', 'TV', 'Minibar', 'Caja fuerte'],
    emoji: '✨',
    color: 'from-indigo-50 to-indigo-100',
    border: 'border-indigo-200',
    badge: '',
  },
  {
    id: 'doble',
    title: 'Habitación Doble',
    price: 85,
    capacity: 4,
    size: '35m²',
    description: 'Dos camas queen. Ideal para familias o grupos pequeños.',
    features: ['WiFi', 'TV', 'Minibar', 'A/C'],
    emoji: '👨‍👩‍👧',
    color: 'from-emerald-50 to-emerald-100',
    border: 'border-emerald-200',
    badge: 'Más popular',
  },
  {
    id: 'doble-familiar',
    title: 'Doble Familiar',
    price: 95,
    capacity: 5,
    size: '40m²',
    description: 'Dos camas queen y zona de estar. Perfecta para familias.',
    features: ['WiFi', 'TV', 'Sala de estar', 'A/C'],
    emoji: '🏡',
    color: 'from-teal-50 to-teal-100',
    border: 'border-teal-200',
    badge: '',
  },
  {
    id: 'suite',
    title: 'Suite Junior',
    price: 120,
    capacity: 2,
    size: '45m²',
    description: 'Sala de estar privada y habitación espaciosa. Lujo colonial.',
    features: ['Sala de estar', 'Minibar', 'Balcón', 'Servicio a hab.'],
    emoji: '🌟',
    color: 'from-amber-50 to-amber-100',
    border: 'border-amber-200',
    badge: '',
  },
  {
    id: 'suite-presidencial',
    title: 'Suite Presidencial',
    price: 150,
    capacity: 2,
    size: '55m²',
    description: 'Suite de lujo con jacuzzi y balcón con vista al centro histórico.',
    features: ['Jacuzzi', 'Balcón', 'Servicio VIP', 'Baño de mármol'],
    emoji: '👑',
    color: 'from-rose-50 to-rose-100',
    border: 'border-rose-200',
    badge: 'Premium',
  },
];
---

<Layout lang={lang} title="Reservar — Hotel Majestic II">
  <!-- Hero Header -->
  <section class="relative h-48 md:h-60 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1611892440504-42a792e24d32?auto=format&fit=crop&w=1920&q=80"
        alt="Reservar habitación"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/50"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <p class="text-accent font-semibold tracking-widest uppercase text-sm mb-2">Hotel Majestic II · Cuenca, Ecuador</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-white mb-2">Reserva tu habitación</h1>
      <p class="text-white/85 text-base max-w-xl mx-auto">Elige fechas, selecciona tu habitación y envía tu solicitud directo por WhatsApp</p>
    </div>
  </section>

  <div class="bg-background min-h-screen">
    <div class="max-w-5xl mx-auto px-4 py-10">

      <!-- Step 1: Dates & Guests -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
        <div class="flex items-center gap-3 mb-5">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">1</span>
          <h2 class="font-display text-xl font-bold text-primary">Fechas y huéspedes</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="form-group">
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide" for="checkin">
              📅 Fecha de ingreso
            </label>
            <input
              type="date"
              id="checkin"
              name="checkin"
              required
              class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all bg-white text-gray-800"
            />
          </div>

          <div class="form-group">
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide" for="checkout">
              📅 Fecha de salida
            </label>
            <input
              type="date"
              id="checkout"
              name="checkout"
              required
              class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all bg-white text-gray-800"
            />
          </div>

          <div class="form-group">
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide" for="adults">
              👥 Adultos
            </label>
            <select
              id="adults"
              name="adults"
              class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all bg-white text-gray-800"
            >
              {[1,2,3,4,5,6,7,8].map(n => (
                <option value={n} selected={n === 2}>{n} adulto{n > 1 ? 's' : ''}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide" for="children">
              🧒 Niños (0–11)
            </label>
            <select
              id="children"
              name="children"
              class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all bg-white text-gray-800"
            >
              {[0,1,2,3,4,5].map(n => (
                <option value={n} selected={n === 0}>{n === 0 ? 'Sin niños' : `${n} niño${n > 1 ? 's' : ''}`}</option>
              ))}
            </select>
          </div>
        </div>

        <!-- Nights summary -->
        <div id="nights-summary" class="hidden mt-4 p-3 bg-primary/5 rounded-lg border border-primary/20">
          <p class="text-sm text-primary font-medium" id="nights-text"></p>
        </div>
      </div>

      <!-- Step 2: Room selection -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
        <div class="flex items-center gap-3 mb-5">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">2</span>
          <h2 class="font-display text-xl font-bold text-primary">Elige tu habitación</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="rooms-grid">
          {rooms.map((room) => (
            <label
              for={`room-${room.id}`}
              class:list={[
                "room-card relative flex flex-col p-4 rounded-xl border-2 cursor-pointer transition-all duration-200 bg-gradient-to-br",
                room.color, room.border,
                "hover:shadow-md hover:-translate-y-0.5"
              ]}
              data-price={room.price}
              data-title={room.title}
            >
              <input
                type="radio"
                id={`room-${room.id}`}
                name="room"
                value={room.id}
                class="sr-only room-radio"
                data-price={room.price}
                data-title={room.title}
              />

              <!-- Badge -->
              {room.badge && (
                <span class="absolute top-3 right-3 text-xs font-bold px-2 py-0.5 rounded-full bg-accent text-white">
                  {room.badge}
                </span>
              )}

              <!-- Check indicator -->
              <span class="room-check absolute top-3 left-3 hidden w-6 h-6 rounded-full bg-primary items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </span>

              <div class="text-3xl mb-2 mt-1">{room.emoji}</div>
              <h3 class="font-display font-bold text-gray-800 text-base mb-0.5">{room.title}</h3>
              <p class="text-xs text-gray-600 mb-2">{room.description}</p>

              <div class="flex flex-wrap gap-1 mb-3">
                {room.features.map(f => (
                  <span class="text-xs px-2 py-0.5 bg-white/70 rounded-full text-gray-700 border border-white/50">{f}</span>
                ))}
              </div>

              <div class="mt-auto flex items-center justify-between">
                <span class="text-xs text-gray-500">👤 Hasta {room.capacity} pers. · {room.size}</span>
                <span class="font-bold text-primary text-lg">${room.price}<span class="text-xs font-normal text-gray-500">/noche</span></span>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Step 3: Extras -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
        <div class="flex items-center gap-3 mb-5">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">3</span>
          <h2 class="font-display text-xl font-bold text-primary">Extras y notas</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <label class="flex items-start gap-3 p-3 rounded-lg border border-gray-200 hover:border-primary/40 cursor-pointer transition-colors">
            <input type="checkbox" id="breakfast" name="breakfast" class="mt-0.5 w-4 h-4 text-primary rounded" />
            <div>
              <p class="text-sm font-semibold text-gray-800">🍳 Desayuno incluido</p>
              <p class="text-xs text-gray-500">Buffet continental (8:00–10:00 am)</p>
            </div>
          </label>

          <label class="flex items-start gap-3 p-3 rounded-lg border border-gray-200 hover:border-primary/40 cursor-pointer transition-colors">
            <input type="checkbox" id="parking" name="parking" class="mt-0.5 w-4 h-4 text-primary rounded" />
            <div>
              <p class="text-sm font-semibold text-gray-800">🚗 Parking</p>
              <p class="text-xs text-gray-500">Estacionamiento privado disponible</p>
            </div>
          </label>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide" for="notes">
            📝 Solicitudes especiales (opcional)
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            placeholder="Ej: cuna para bebé, piso alto, llegada tardía..."
            class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all bg-white resize-none placeholder:text-gray-400"
          ></textarea>
        </div>
      </div>

      <!-- Summary & CTA -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center gap-3 mb-5">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent text-white font-bold text-sm">✓</span>
          <h2 class="font-display text-xl font-bold text-primary">Resumen de tu reserva</h2>
        </div>

        <div id="booking-summary" class="mb-5 p-4 bg-gray-50 rounded-xl border border-gray-200 text-sm text-gray-700 space-y-1.5">
          <p class="text-gray-400 text-center py-2">Completa los pasos anteriores para ver el resumen</p>
        </div>

        <button
          id="send-whatsapp-btn"
          type="button"
          disabled
          class="w-full flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#20bb5a] disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 text-base shadow-md hover:shadow-lg hover:shadow-[#25D366]/30 transform hover:-translate-y-0.5 disabled:transform-none disabled:shadow-none"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span id="whatsapp-btn-text">Enviar reserva por WhatsApp</span>
        </button>

        <p class="text-center text-xs text-gray-400 mt-3">
          Tu solicitud se enviará directamente a nuestro equipo. Te confirmaremos disponibilidad y precio a la brevedad.
        </p>
      </div>

    </div>
  </div>
</Layout>

<style>
  .room-card:has(.room-radio:checked) {
    border-color: #1e3a8a;
    box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.15);
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
  }

  .room-card:has(.room-radio:checked) .room-check {
    display: flex;
  }
</style>

<script>
  const checkinInput = document.getElementById('checkin') as HTMLInputElement;
  const checkoutInput = document.getElementById('checkout') as HTMLInputElement;
  const adultsSelect = document.getElementById('adults') as HTMLSelectElement;
  const childrenSelect = document.getElementById('children') as HTMLSelectElement;
  const breakfastCheck = document.getElementById('breakfast') as HTMLInputElement;
  const parkingCheck = document.getElementById('parking') as HTMLInputElement;
  const notesInput = document.getElementById('notes') as HTMLTextAreaElement;
  const nightsSummary = document.getElementById('nights-summary');
  const nightsText = document.getElementById('nights-text');
  const bookingSummary = document.getElementById('booking-summary');
  const sendBtn = document.getElementById('send-whatsapp-btn') as HTMLButtonElement;
  const sendBtnText = document.getElementById('whatsapp-btn-text');

  // Set min dates
  const today = new Date();
  const todayStr = today.toISOString().split('T')[0];
  checkinInput.min = todayStr;
  checkoutInput.min = todayStr;

  function getSelectedRoom(): { id: string; title: string; price: number } | null {
    const radio = document.querySelector('.room-radio:checked') as HTMLInputElement | null;
    if (!radio) return null;
    return {
      id: radio.value,
      title: radio.dataset.title || radio.value,
      price: Number(radio.dataset.price) || 0,
    };
  }

  function calcNights(): number {
    if (!checkinInput.value || !checkoutInput.value) return 0;
    const ci = new Date(checkinInput.value);
    const co = new Date(checkoutInput.value);
    const diff = Math.ceil((co.getTime() - ci.getTime()) / 86400000);
    return diff > 0 ? diff : 0;
  }

  function formatDate(dateStr: string): string {
    if (!dateStr) return '';
    const [y, m, d] = dateStr.split('-');
    return `${d}/${m}/${y}`;
  }

  function updateNightsSummary() {
    const nights = calcNights();
    if (nights > 0 && nightsSummary && nightsText) {
      nightsText.textContent = `✅ ${nights} noche${nights > 1 ? 's' : ''} — del ${formatDate(checkinInput.value)} al ${formatDate(checkoutInput.value)}`;
      nightsSummary.classList.remove('hidden');
    } else if (nightsSummary) {
      nightsSummary.classList.add('hidden');
    }
  }

  function isFormValid(): boolean {
    const nights = calcNights();
    const room = getSelectedRoom();
    return nights > 0 && room !== null;
  }

  function updateSummary() {
    if (!bookingSummary) return;
    const nights = calcNights();
    const room = getSelectedRoom();
    const adults = adultsSelect.value;
    const children = childrenSelect.value;
    const breakfast = breakfastCheck.checked;
    const parking = parkingCheck.checked;
    const notes = notesInput.value.trim();

    if (!isFormValid()) {
      bookingSummary.innerHTML = '<p class="text-gray-400 text-center py-2">Completa los pasos anteriores para ver el resumen</p>';
      sendBtn.disabled = true;
      if (sendBtnText) sendBtnText.textContent = 'Enviar reserva por WhatsApp';
      return;
    }

    const totalPrice = (room!.price * nights);

    bookingSummary.innerHTML = `
      <div class="grid grid-cols-2 gap-x-6 gap-y-1.5">
        <div><span class="text-gray-500">🛏️ Habitación:</span> <strong>${room!.title}</strong></div>
        <div><span class="text-gray-500">💰 Precio base:</span> <strong>$${room!.price}/noche × ${nights} = $${totalPrice}</strong></div>
        <div><span class="text-gray-500">📅 Ingreso:</span> <strong>${formatDate(checkinInput.value)}</strong></div>
        <div><span class="text-gray-500">📅 Salida:</span> <strong>${formatDate(checkoutInput.value)}</strong></div>
        <div><span class="text-gray-500">👥 Adultos:</span> <strong>${adults}</strong></div>
        <div><span class="text-gray-500">🧒 Niños:</span> <strong>${children}</strong></div>
        <div><span class="text-gray-500">🍳 Desayuno:</span> <strong>${breakfast ? 'Sí' : 'No'}</strong></div>
        <div><span class="text-gray-500">🚗 Parking:</span> <strong>${parking ? 'Sí' : 'No'}</strong></div>
        ${notes ? `<div class="col-span-2"><span class="text-gray-500">📝 Notas:</span> <strong>${notes}</strong></div>` : ''}
      </div>
      <div class="mt-3 pt-3 border-t border-gray-300 flex items-center justify-between">
        <span class="text-gray-500 text-xs">*Precio orientativo. Se confirmará disponibilidad.</span>
        <span class="text-lg font-bold text-primary">Total est.: $${totalPrice}</span>
      </div>
    `;

    sendBtn.disabled = false;
    if (sendBtnText) sendBtnText.textContent = `Enviar solicitud por WhatsApp ($${totalPrice} est.)`;
  }

  function sendToWhatsApp() {
    const nights = calcNights();
    const room = getSelectedRoom();
    if (!room || nights <= 0) return;

    const adults = adultsSelect.value;
    const children = childrenSelect.value;
    const breakfast = breakfastCheck.checked ? 'Sí ✅' : 'No';
    const parking = parkingCheck.checked ? 'Sí ✅' : 'No';
    const notes = notesInput.value.trim();
    const total = room.price * nights;

    let msg = `*¡Hola! Quiero hacer una reserva en Hotel Majestic II.*%0A%0A`;
    msg += `🛏️ *Habitación:* ${room.title}%0A`;
    msg += `📅 *Ingreso:* ${formatDate(checkinInput.value)}%0A`;
    msg += `📅 *Salida:* ${formatDate(checkoutInput.value)}%0A`;
    msg += `🌙 *Noches:* ${nights}%0A`;
    msg += `👥 *Adultos:* ${adults} | *Niños:* ${children}%0A`;
    msg += `💰 *Precio estimado:* $${room.price}/noche × ${nights} noches = *$${total}*%0A`;
    msg += `%0A🏷️ *Extras:*%0A`;
    msg += `   • Desayuno: ${breakfast}%0A`;
    msg += `   • Parking: ${parking}%0A`;
    if (notes) msg += `%0A📝 *Solicitudes especiales:* ${notes}%0A`;
    msg += `%0APor favor confirmar disponibilidad y tarifa. ¡Gracias!`;

    window.open(`https://wa.me/593980098757?text=${msg}`, '_blank');
  }

  // Event listeners
  checkinInput.addEventListener('change', () => {
    if (checkinInput.value) {
      const nextDay = new Date(checkinInput.value);
      nextDay.setDate(nextDay.getDate() + 1);
      checkoutInput.min = nextDay.toISOString().split('T')[0];
      if (checkoutInput.value && checkoutInput.value <= checkinInput.value) {
        checkoutInput.value = nextDay.toISOString().split('T')[0];
      }
    }
    updateNightsSummary();
    updateSummary();
  });

  checkoutInput.addEventListener('change', () => {
    updateNightsSummary();
    updateSummary();
  });

  adultsSelect.addEventListener('change', updateSummary);
  childrenSelect.addEventListener('change', updateSummary);
  breakfastCheck.addEventListener('change', updateSummary);
  parkingCheck.addEventListener('change', updateSummary);
  notesInput.addEventListener('input', updateSummary);

  document.querySelectorAll('.room-radio').forEach(radio => {
    radio.addEventListener('change', updateSummary);
  });

  sendBtn.addEventListener('click', sendToWhatsApp);

  // Init
  updateSummary();
</script>
