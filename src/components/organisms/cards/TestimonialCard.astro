---
interface Props {
  name: string;
  date?: string;
  rating?: number;
  text: string;
  image?: string;
}

const { name, date, rating = 5, text, image } = Astro.props;
---

<blockquote class="card p-6">
  <div class="flex items-start space-x-4">
    {image ? (
      <img 
        src={image} 
        alt={name}
        class="w-14 h-14 rounded-full object-cover flex-shrink-0"
      />
    ) : (
      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center flex-shrink-0">
        <span class="text-white font-display text-xl font-bold">{name.charAt(0)}</span>
      </div>
    )}
    
    <div class="flex-1">
      <div class="flex items-center justify-between mb-2">
        <cite class="font-medium text-primary not-italic">{name}</cite>
<div class="flex items-center">
          {[...Array(5)].map((_, i) => (
            <svg 
              class:list={[
                'w-4 h-4',
                i < rating ? 'text-accent' : 'text-gray-200'
              ]} 
              xmlns="http://www.w3.org/2000/svg" 
              viewBox="0 0 20 20" 
              fill="currentColor"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
      
      <p class="text-text-light font-accent text-base leading-relaxed mb-3">{text}</p>
      
      {date && (
        <time class="text-sm text-text-muted">{date}</time>
      )}
    </div>
  </div>
</blockquote>