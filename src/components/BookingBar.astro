---
interface Props {
  variant?: 'floating' | 'inline';
}

const { variant = 'inline' } = Astro.props;
---

<div class:list={[
  'booking-bar-container',
  variant === 'floating' ? 'fixed bottom-4 left-4 right-4 md:left-auto md:right-auto md:w-full max-w-5xl md:rounded-2xl shadow-2xl z-40' : 'relative'
]}>
  <div class:list={[
  'booking-bar',
  variant === 'floating' ? 'bg-white md:rounded-2xl' : ''
]}>
    <slot />
  </div>
</div>
