---
interface Props {
  variant?: 'hero' | 'page';
}

const { variant = 'hero' } = Astro.props;
---

<form id="booking-form" class:list={[
  'booking-form',
  variant === 'hero' ? 'bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl p-4 md:p-5' : 'bg-white rounded-xl shadow-lg border border-gray-100 p-6'
]}>
  <!-- Primary Row: Compact Inputs -->
  <div class:list={[
    'grid gap-2 md:gap-3',
    variant === 'hero' ? 'grid-cols-2 md:grid-cols-5' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-5'
  ]}>
    <!-- Check-in -->
    <div class="form-group">
      <label class="text-xs font-medium text-text-light mb-1" for="checkin-hero">Llegada</label>
      <input 
        type="date" 
        id="checkin-hero" 
        name="checkin" 
        class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all bg-white"
        required 
      />
    </div>

    <!-- Check-out -->
    <div class="form-group">
      <label class="text-xs font-medium text-text-light mb-1" for="checkout-hero">Salida</label>
      <input 
        type="date" 
        id="checkout-hero" 
        name="checkout" 
        class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all bg-white"
        required 
      />
    </div>

    <!-- Adults -->
    <div class="form-group">
      <label class="text-xs font-medium text-text-light mb-1" for="adults-hero">Adultos</label>
      <select 
        id="adults-hero" 
        name="adults" 
        class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all bg-white"
      >
        <option value="1" selected>1 adulto</option>
        <option value="2">2 adultos</option>
        <option value="3">3 adultos</option>
        <option value="4">4 adultos</option>
        <option value="5">5 adultos</option>
        <option value="6">6 adultos</option>
      </select>
    </div>

    <!-- Children -->
    <div class="form-group">
      <label class="text-xs font-medium text-text-light mb-1" for="children-hero">Niños</label>
      <select 
        id="children-hero" 
        name="children" 
        class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all bg-white"
      >
        <option value="0" selected>Sin niños</option>
        <option value="1">1 niño</option>
        <option value="2">2 niños</option>
        <option value="3">3 niños</option>
      </select>
    </div>

    <!-- Rooms -->
    <div class="form-group">
      <label class="text-xs font-medium text-text-light mb-1" for="rooms-hero">Habitaciones</label>
      <select 
        id="rooms-hero" 
        name="rooms" 
        class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all bg-white"
      >
        <option value="1" selected>1 habitación</option>
        <option value="2">2 habitaciones</option>
        <option value="3">3 habitaciones</option>
      </select>
    </div>
  </div>

  <!-- Expandible: Additional Options -->
  <div class="mt-3 pt-3 border-t border-gray-200">
    <button 
      type="button" 
      id="toggle-options-hero" 
      class="text-xs font-medium text-primary hover:text-accent transition-colors flex items-center"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
      <span>Más opciones</span>
    </button>
    
    <div id="additional-options-hero" class="hidden mt-3 space-y-3">
      <!-- Switch Toggles -->
      <div class="flex flex-wrap gap-2">
        <button type="button" data-switch="tours" class="toggle-switch px-3 py-1.5 text-xs font-medium border border-gray-200 rounded-full hover:border-primary transition-colors">
          Tours (+$25)
        </button>
        <button type="button" data-switch="breakfast" class="toggle-switch px-3 py-1.5 text-xs font-medium border border-gray-200 rounded-full hover:border-primary transition-colors">
          Desayuno (+$15)
        </button>
        <button type="button" data-switch="parking" class="toggle-switch px-3 py-1.5 text-xs font-medium border border-gray-200 rounded-full hover:border-primary transition-colors">
          Parqueadero (+$10)
        </button>
      </div>
      
      <!-- Hidden inputs for toggles (populated by JS) -->
      <input type="hidden" name="tours" id="tours-input" value="" />
      <input type="hidden" name="breakfast" id="breakfast-input" value="" />
      <input type="hidden" name="parking" id="parking-input" value="" />
      
      <!-- Special Requests -->
      <div>
        <textarea 
          id="special-requests-hero" 
          name="special-requests" 
          rows="2" 
          class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all resize-none bg-white"
          placeholder="Peticiones especiales: cama extra, almohadas, necesidades dietéticas..."
        ></textarea>
      </div>
    </div>
  </div>

  <!-- Submit Button -->
  <button type="submit" class="mt-3 w-full bg-accent hover:bg-accent-dark text-white font-bold py-2.5 px-4 rounded-lg transition-all duration-300 flex items-center justify-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="text-sm">Ver disponibilidad</span>
  </button>
</form>

<script>
  // Toggle additional options
  const toggleBtn = document.getElementById('toggle-options-hero');
  const optionsSection = document.getElementById('additional-options-hero');
  const toggleIcon = toggleBtn?.querySelector('svg');
  
  if (toggleBtn && optionsSection) {
    toggleBtn.addEventListener('click', () => {
      optionsSection.classList.toggle('hidden');
      if (toggleIcon) {
        toggleIcon.classList.toggle('rotate-45');
      }
    });
  }

  // Toggle switches
  const toggleSwitches = document.querySelectorAll('.toggle-switch');
  
  toggleSwitches.forEach(switchBtn => {
    switchBtn.addEventListener('click', () => {
      switchBtn.classList.toggle('bg-primary');
      switchBtn.classList.toggle('text-white');
      switchBtn.classList.toggle('border-primary');
      switchBtn.classList.toggle('border-gray-200');
      
      // Update hidden input
      const switchName = switchBtn.getAttribute('data-switch');
      const hiddenInput = document.getElementById(`${switchName}-input`) as HTMLInputElement;
      if (hiddenInput) {
        hiddenInput.value = switchBtn.classList.contains('bg-primary') ? 'on' : '';
      }
    });
  });

  // Set minimum date to today
  const today = new Date().toISOString().split('T')[0];
  const checkinInput = document.getElementById('checkin-hero') as HTMLInputElement;
  const checkoutInput = document.getElementById('checkout-hero') as HTMLInputElement;
  
  if (checkinInput && checkoutInput) {
    checkinInput.min = today;
    checkoutInput.min = today;

    checkinInput.addEventListener('change', () => {
      const checkinDate = new Date(checkinInput.value);
      checkinDate.setDate(checkinDate.getDate() + 1);
      const minCheckout = checkinDate.toISOString().split('T')[0];
      checkoutInput.min = minCheckout;
      
      if (checkoutInput.value && checkoutInput.value <= checkinInput.value) {
        checkoutInput.value = minCheckout;
      }
    });
  }

  // Form submission
  const form = document.getElementById('booking-form') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        adults: formData.get('adults'),
        children: formData.get('children'),
        rooms: formData.get('rooms'),
        checkin: formData.get('checkin'),
        checkout: formData.get('checkout'),
        tours: formData.get('tours') ? 'Sí' : 'No',
        breakfast: formData.get('breakfast') ? 'Sí' : 'No',
        parking: formData.get('parking') ? 'Sí' : 'No',
        specialRequests: formData.get('special-requests') || 'Ninguna'
      };

      // Calculate nights
      const checkIn = new Date(data.checkin as string);
      const checkOut = new Date(data.checkout as string);
      const nights = Math.ceil((checkOut.getTime() - checkIn.getTime()) / (1000 * 60 * 60 * 24));

      // Build WhatsApp message
      const message = `*¡Hola! Me interesa reservar en Hotel Majestic II.*%0A%0A📅 *Check-in:* ${data.checkin}%0A📅 *Check-out:* ${data.checkout} (${nights} noche${nights > 1 ? 's' : ''})%0A🛏️ *Adultos:* ${data.adults} | *Niños:* ${data.children} | *Habitaciones:* ${data.rooms}%0A%0A🏷️ *Extras:*%0A   Tours: ${data.tours}%0A   Desayuno: ${data.breakfast}%0A   Parqueadero: ${data.parking}%0A%0A📝 *Notas:* ${data.specialRequests}%0A%0APor favor confirmar disponibilidad y tarifa.`;

      // Redirect to WhatsApp
      window.open(`https://wa.me/593980098757?text=${message}`, '_blank');
    });
  }
</script>