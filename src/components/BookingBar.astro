---
interface Props {
  variant?: 'floating' | 'inline';
}

const { variant = 'floating' } = Astro.props;
---

<div class:list={[
  'booking-bar',
  variant === 'floating' ? 'fixed bottom-4 left-4 right-4 md:left-auto md:right-auto md:w-full max-w-5xl md:rounded-2xl shadow-2xl z-40' : 'relative bg-white rounded-xl shadow-lg border border-gray-100'
]}>
  <form id="booking-form" class:list={[
  'booking-form',
  variant === 'floating' ? 'bg-white md:rounded-2xl p-4 md:p-6' : 'p-6'
]}>
    <div class:list={[
      'grid gap-4',
      variant === 'floating' ? 'grid-cols-2 md:grid-cols-6' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4'
    ]}>
      <!-- Adults -->
      <div class="form-group">
        <label class="label" for="adults">Adultos</label>
        <select id="adults" name="adults" class="input-field">
          <option value="1" selected>1 adulto</option>
          <option value="2">2 adultos</option>
          <option value="3">3 adultos</option>
          <option value="4">4 adultos</option>
          <option value="5">5 adultos</option>
          <option value="6">6 adultos</option>
          <option value="7">7 adultos</option>
          <option value="8">8 adultos</option>
          <option value="9">9 adultos</option>
          <option value="10">10 adultos</option>
        </select>
      </div>

      <!-- Children -->
      <div class="form-group">
        <label class="label" for="children">Niños</label>
        <select id="children" name="children" class="input-field">
          <option value="0" selected>Sin niños</option>
          <option value="1">1 niño</option>
          <option value="2">2 niños</option>
          <option value="3">3 niños</option>
          <option value="4">4 niños</option>
          <option value="5">5 niños</option>
        </select>
      </div>

      <!-- Rooms -->
      <div class="form-group">
        <label class="label" for="rooms">Habitaciones</label>
        <select id="rooms" name="rooms" class="input-field">
          <option value="1" selected>1 habitación</option>
          <option value="2">2 habitaciones</option>
          <option value="3">3 habitaciones</option>
          <option value="4">4 habitaciones</option>
          <option value="5">5 habitaciones</option>
        </select>
      </div>

      <!-- Check-in -->
      <div class="form-group">
        <label class="label" for="checkin">Check-in</label>
        <input type="date" id="checkin" name="checkin" class="input-field" required />
      </div>

      <!-- Check-out -->
      <div class="form-group">
        <label class="label" for="checkout">Check-out</label>
        <input type="date" id="checkout" name="checkout" class="input-field" required />
      </div>
    </div>

    <!-- Additional Options (collapsible on mobile) -->
    <div class="mt-4 pt-4 border-t border-gray-100">
      <button type="button" id="toggle-options" class="text-sm text-primary font-medium hover:text-accent transition-colors flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        Opciones adicionales
      </button>
      
      <div id="additional-options" class="hidden mt-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
            <input type="checkbox" name="tours" value="tours" class="w-5 h-5 text-primary rounded focus:ring-primary" />
            <span class="ml-2 text-sm">Tours guiados (+$25/persona)</span>
          </label>
          
          <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
            <input type="checkbox" name="breakfast" value="breakfast" class="w-5 h-5 text-primary rounded focus:ring-primary" />
            <span class="ml-2 text-sm">Desayuno incluido (+$15/persona)</span>
          </label>
          
          <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
            <input type="checkbox" name="parking" value="parking" class="w-5 h-5 text-primary rounded focus:ring-primary" />
            <span class="ml-2 text-sm">Parqueadero (+$10/noche)</span>
          </label>
        </div>
        
        <div class="mt-4">
          <label class="label" for="special-requests">Peticiones especiales</label>
          <textarea id="special-requests" name="special-requests" rows="2" class="input-field resize-none" placeholder="Cama extra, almohadas adicionales, necesidades dietéticas..."></textarea>
        </div>
      </div>
    </div>

    <!-- Submit Button -->
    <div class="mt-4">
      <button type="submit" class="btn-accent w-full md:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        Ver disponibilidad
      </button>
    </div>
  </form>
</div>

<script>
  // Toggle additional options
  const toggleBtn = document.getElementById('toggle-options');
  const optionsSection = document.getElementById('additional-options');
  
  if (toggleBtn && optionsSection) {
    toggleBtn.addEventListener('click', () => {
      optionsSection.classList.toggle('hidden');
    });
  }

  // Set minimum date to today
  const today = new Date().toISOString().split('T')[0];
  const checkinInput = document.getElementById('checkin') as HTMLInputElement;
  const checkoutInput = document.getElementById('checkout') as HTMLInputElement;
  
  if (checkinInput && checkoutInput) {
    checkinInput.min = today;
    checkoutInput.min = today;

    checkinInput.addEventListener('change', () => {
      const checkinDate = new Date(checkinInput.value);
      checkinDate.setDate(checkinDate.getDate() + 1);
      const minCheckout = checkinDate.toISOString().split('T')[0];
      checkoutInput.min = minCheckout;
      
      if (checkoutInput.value && checkoutInput.value <= checkinInput.value) {
        checkoutInput.value = minCheckout;
      }
    });
  }

  // Form submission
  const form = document.getElementById('booking-form') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        adults: formData.get('adults'),
        children: formData.get('children'),
        rooms: formData.get('rooms'),
        checkin: formData.get('checkin'),
        checkout: formData.get('checkout'),
        tours: formData.get('tours') ? 'Sí' : 'No',
        breakfast: formData.get('breakfast') ? 'Sí' : 'No',
        parking: formData.get('parking') ? 'Sí' : 'No',
        specialRequests: formData.get('special-requests') || 'Ninguna'
      };

      // Calculate nights
      const checkIn = new Date(data.checkin as string);
      const checkOut = new Date(data.checkout as string);
      const nights = Math.ceil((checkOut.getTime() - checkIn.getTime()) / (1000 * 60 * 60 * 24));

      // Build WhatsApp message
      const message = `*¡Hola! Me interesa reservar en Hotel Majestic II.*%0A%0A📅 *Check-in:* ${data.checkin}%0A📅 *Check-out:* ${data.checkout} (${nights} noche${nights > 1 ? 's' : ''})%0A🛏️ *Adultos:* ${data.adults} | *Niños:* ${data.children} | *Habitaciones:* ${data.rooms}%0A%0A🏷️ *Extras:*%0A   Tours: ${data.tours}%0A   Desayuno: ${data.breakfast}%0A   Parqueadero: ${data.parking}%0A%0A📝 *Notas:* ${data.specialRequests}%0A%0APor favor confirmar disponibilidad y tarifa.`;

      // Redirect to WhatsApp
      window.open(`https://wa.me/593980098757?text=${message}`, '_blank');
    });
  }
</script>