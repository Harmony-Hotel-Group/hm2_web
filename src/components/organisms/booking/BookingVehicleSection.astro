---
interface Props {
  id?: string;
}

const { id = 'vehicle-section' } = Astro.props;

const vehicleTypes = [
  { value: 'car', label: 'Automóvil' },
  { value: 'motorcycle', label: 'Motocicleta' },
  { value: 'van', label: 'Van' },
  { value: 'truck', label: 'Camión' },
  { value: 'other', label: 'Otro' }
];
---

<div id={id} class="vehicle-section hidden mt-4 p-4 bg-gray-50 rounded-lg border border-gray-500 text-black">
  <div class="flex items-center justify-between mb-4">
    <h4 class="text-sm font-semibold text-black">Vehículos</h4>
    <button type="button" id="add-vehicle" class="text-sm text-primary hover:text-accent font-medium flex items-center">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Agregar
    </button>
  </div>
  
  <div id="vehicle-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
    <!-- Vehicles will be added here dynamically -->
  </div>
  
  <p class="text-xs text-black mt-2">Máximo 6 vehículos</p>
</div>

<template id="vehicle-item-template">
  <div class="vehicle-item relative flex flex-col gap-2 p-3 bg-white rounded-lg border border-gray-500">
    <!-- Botón eliminar en esquina superior derecha tipo X de tarjeta -->
    <button type="button" class="remove-vehicle absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center hover:bg-red-600 transition-colors shadow-md z-10">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-2">
      <select name="vehicleType" class="input-field w-full h-[42px] text-sm text-black border-gray-500">
        <option value="">Tipo</option>
        {vehicleTypes.map((type) => (
          <option value={type.value}>{type.label}</option>
        ))}
      </select>
      <input type="text" name="vehiclePlate" placeholder="Placa" class="input-field w-full h-[42px] text-sm text-black border-gray-500 placeholder:text-gray-700 uppercase" maxlength="10" />
    </div>
  </div>
</template>

<script>
  const vehicleList = document.getElementById('vehicle-list');
  const addVehicleBtn = document.getElementById('add-vehicle');
  const template = document.getElementById('vehicle-item-template') as HTMLTemplateElement | null;
  
  let vehicleCount = 0;
  const maxVehicles = 6;

  function addVehicle() {
    if (vehicleCount >= maxVehicles || !template) return;
    
    const clone = template.content.cloneNode(true) as DocumentFragment;
    const item = clone.querySelector('.vehicle-item');
    
    if (item) {
      const elements = item.querySelectorAll('select, input') as NodeListOf<HTMLInputElement | HTMLSelectElement>;
      elements.forEach((htmlEl) => {
        htmlEl.name = htmlEl.name + vehicleCount;
      });
    }
    
    vehicleList?.appendChild(clone);
    vehicleCount++;
    
    if (item) {
      item.querySelector('.remove-vehicle')?.addEventListener('click', () => {
        item.remove();
        vehicleCount--;
      });
    }
  }

  addVehicleBtn?.addEventListener('click', addVehicle);
</script>
